import os, re, shutil, io, fitz, easyocr, math, logging
import pandas as pd
from PIL import Image
from datetime import datetime as dt

# Configuração de Log
logging.basicConfig(level=logging.INFO, format="%(asctime)s [%(levelname)s] %(message)s")
log = logging.getLogger(__name__)

# --- CONFIGURAÇÕES DE CAMINHO ---
diretorio_entrada = r"\\saos003fs03p\ProcessosBI\MIS\Datasources\Juridico\Oficios SUSEP Juridco - PDF PBI\2 in progress"
base_done = r"\\saos003fs03p\ProcessosBI\MIS\Datasources\Juridico\Oficios SUSEP Juridco - PDF PBI\3_done"

# Inicializa o Reader fora do loop para não recarregar o modelo em cada arquivo (ganho de performance)
reader = easyocr.Reader(['pt', 'en'], gpu=False)

def formatar_documento(numero, tipo):
    if tipo == "CPF": return f"{numero[:3]}.{numero[3:6]}.{numero[6:9]}-{numero[9:]}" if len(numero) == 11 else numero
    if tipo == "CNPJ": return f"{numero[:2]}.{numero[2:5]}.{numero[5:8]}/{numero[8:12]}-{numero[12:]}" if len(numero) == 14 else numero
    return numero

def organizar_arquivos_processados(identificador_oficio, caminho_pdf_original):
    try:
        ano = identificador_oficio.split('_')[-1]
        caminho_ano = os.path.join(base_done, ano)
        caminho_pasta_oficio = os.path.join(caminho_ano, f"Ofício {identificador_oficio}")
        os.makedirs(caminho_pasta_oficio, exist_ok=True)
        
        nome_pdf = os.path.basename(caminho_pdf_original)
        destino_pdf = os.path.join(caminho_pasta_oficio, nome_pdf)
        
        shutil.move(caminho_pdf_original, destino_pdf)
        log.info(f"✔ PDF movido para: {destino_pdf}")
        return True
    except Exception as e:
        log.error(f"✘ Erro ao organizar arquivos: {e}")
        return False

# --- LISTAGEM DE ARQUIVOS ---
arquivos_pdf = [f for f in os.listdir(diretorio_entrada) if f.lower().endswith('.pdf')]

if not arquivos_pdf:
    log.info("Nenhum arquivo PDF encontrado para processar.")

for nome_arquivo in arquivos_pdf:
    caminho_completo = os.path.join(diretorio_entrada, nome_arquivo)
    log.info(f"--- Iniciando processamento: {nome_arquivo} ---")
    
    linhas_dados_extraidos = []
    identificador_oficio = "00_0000"
    
    try:
        # 1. Tenta abrir o documento
        doc_pdf = fitz.open(caminho_completo)
        
        for i, page in enumerate(doc_pdf):
            page_label = f"Page{i+1:04}"
            texto_extraido = page.get_text("text").strip()
            origem_dado = "TEXTO_NATIVO"
            
            # Regex patterns
            regex_cpf = r"\b\d{3}\.\d{3}\.\d{3}-\d{2}\b"
            regex_cpf_1 = r"\b\d{11}\b"
            regex_cnpj = r"\b\d{2}\.\d{3}\.\d{3}/\d{4}-\d{2}\b"
            regex_cnpj_1 = r"\b\d{14}\b"
            regex_cnpj_2 = r"\d{2}[\s\S]{0,3}\d{3}[\s\S]{0,3}\d{3}[\s\S]{0,3}\d{4}[\s\S]{0,3}\d{2}"
            regex_n_oficio = r"(?:N[º°ºª]\s*)(\d+)[/\-](\d{4})"
            remove_char = lambda x: re.sub(r"[^\d]", "", x)

            # Busca Ofício na página 1
            if i == 0:
                match = re.search(regex_n_oficio, texto_extraido)
                if match:
                    num, ano = match.groups()
                    identificador_oficio = f"{num}_{ano}"
                    log.info(f">>> Ofício identificado: {identificador_oficio}")

            # Lógica de Imagem/OCR
            lista_imagens = page.get_images(full=True)
            if not re.findall(regex_cpf, texto_extraido) and not re.findall(regex_cnpj, texto_extraido):
                for img in lista_imagens:
                    largura, altura = img[2], img[3]
                    if (700 <= largura <= 980) and (400 <= altura <= 980):
                        areas = page.get_image_rects(img)
                        if areas:
                            pix = page.get_pixmap(matrix=fitz.Matrix(2, 2), clip=areas[0]) # DPI menor para velocidade
                            img_bytes = pix.tobytes("jpg")
                            texto_ocr = " ".join(reader.readtext(img_bytes, detail=0))
                            texto_extraido += " " + texto_ocr
                            origem_dado = "OCR"
                            break

            # Processamento de linhas e documentos
            if texto_extraido:
                linhas = texto_extraido.split("\n")
                for num_linha, linha in enumerate(linhas):
                    for tipo, reg in [("CPF", regex_cpf), ("CPF", regex_cpf_1), ("CNPJ", regex_cnpj), ("CNPJ", regex_cnpj_1), ("CNPJ", regex_cnpj_2)]:
                        for doc_found in re.findall(reg, linha):
                            doc_limpo = remove_char(doc_found)
                            if (tipo == "CPF" and len(doc_limpo) == 11) or (tipo == "CNPJ" and len(doc_limpo) == 14):
                                linhas_dados_extraidos.append({
                                    "OficioRef": identificador_oficio,
                                    "Page": page_label,
                                    "ClienteCpfCnpj": formatar_documento(doc_limpo, tipo),
                                    "Tipo": tipo,
                                    "Origem": origem_dado
                                })
        
        doc_pdf.close()

        # Finalização do Arquivo atual
        if linhas_dados_extraidos:
            df_final = pd.DataFrame(linhas_dados_extraidos).drop_duplicates()
            # Aqui você inseriria sua lógica de SQL (gerar_variavel_string_split)
            log.info(f"✔ {len(df_final)} registros extraídos do arquivo {nome_arquivo}")
        
        # Move o arquivo para a pasta final
        organizar_arquivos_processados(identificador_oficio, caminho_completo)

    except Exception as e:
        log.error(f"✘ Erro crítico ao processar o arquivo {nome_arquivo}: {e}")
        continue # Pula para o próximo PDF da lista

log.info("Processamento de todos os arquivos concluído.")
