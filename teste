import os
import shutil

def organizar_arquivos_processados(identificador_oficio, caminho_pdf_original, caminho_excel_gerado):
    """
    Organiza o PDF e o Excel em uma estrutura de pastas: 3_done > ANO > Ofício XXX_AAAA
    """
    base_done = r"\\saos003fs03p\ProcessosBI\MIS\Datasources\Juridico\Oficios SUSEP Juridco - PDF PBI\3_done"
    
    try:
        # 1. Extrai o ano do identificador (ex: "15_2026" -> "2026")
        ano = identificador_oficio.split('_')[-1]
        
        # 2. Define e cria os caminhos (Ano e Pasta do Ofício)
        caminho_ano = os.path.join(base_done, ano)
        caminho_pasta_oficio = os.path.join(caminho_ano, f"Ofício {identificador_oficio}")
        
        # os.makedirs com exist_ok=True evita erros se a pasta já existir
        os.makedirs(caminho_pasta_oficio, exist_ok=True)
        
        # 3. Move os arquivos
        # Pegamos apenas o nome do arquivo para o destino
        nome_pdf = os.path.basename(caminho_pdf_original)
        nome_excel = os.path.basename(caminho_excel_gerado)
        
        shutil.move(caminho_pdf_original, os.path.join(caminho_pasta_oficio, nome_pdf))
        shutil.move(caminho_excel_gerado, os.path.join(caminho_pasta_oficio, nome_excel))
        
        log.info(f"✔ Arquivos organizados com sucesso em: {caminho_pasta_oficio}")
        return True

    except Exception as e:
        log.error(f"✘ Erro ao organizar arquivos: {e}")
        return False

