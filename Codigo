def data_hora():
    return dt.now().strftime("%d/%m/%Y %H:%M:%S")

def formatar_documento(numero, tipo):
    """ Formata a string para exibição bonitinha (com pontos e traços) """
    if tipo == "CPF":
        return f"{numero[:3]}.{numero[3:6]}.{numero[6:9]}-{numero[9:]}" if len(numero) == 11 else numero
    if tipo == "CNPJ":
        return f"{numero[:2]}.{numero[2:5]}.{numero[5:8]}/{numero[8:12]}-{numero[12:]}" if len(numero) == 14 else numero
    return numero

def gerar_variavel_string_split(df):
    """ Gera query SQL com DECLARE @Valores para inserção em blocos """
    if df.empty: return "DECLARE @Valores TABLE (Page NVARCHAR(MAX)); -- Sem dados"
    
    colunas = list(df.columns)
    colunas_str = ", ".join(colunas)
    tabela_def = ", ".join([f"[{col}] NVARCHAR(MAX)" for col in colunas])
    
    valores = df.astype(str).values.tolist()
    # Escapa aspas simples para o SQL
    valores_formatados = [ "(" + ", ".join(["'" + v.replace("'", "''") + "'" for v in linha ]) + ")" for linha in valores ]
    
    num_blocos = math.ceil(len(valores_formatados) / 1000)
    queries = []
    
    for i in range(num_blocos):
        bloco = valores_formatados[i * 1000 : (i + 1) * 1000]
        valores_str = ",\n      ".join(bloco)
        queries.append(f"INSERT INTO @Valores ({colunas_str})\nVALUES\n      {valores_str};")
    
    query = f"SET NOCOUNT ON;\nDECLARE @Valores TABLE ({tabela_def});\n" + "\n".join(queries)
    return query

def info_conexao(driver, server):
    try:
        connection = pyodbc.connect(f'DRIVER={driver};SERVER={server};Trusted_Connection=yes;')
        log.info(f"Conectado ao servidor: {server}")
        return connection
    except pyodbc.Error as e:
        log.error(f"Erro ao conectar ao {server}: {e}")
        return None

# --- EXECUÇÃO PRINCIPAL ---
log.info(" Etapa 01/04: Iniciando leitura do PDF com suporte a OCR...")

# Caminhos
diretorio = r"\\saos003fs03p/ProcessosBI/MIS/Datasources/Juridico/Oficios SUSEP Juridco - PDF PBI/2 in progress/"
nome_arquivo = 'PDF_IMPORT'
arquivo_path = os.path.join(diretorio, nome_arquivo + ".pdf")

# Regex e Limpeza
regex_cpf = r"\b\d{3}\.?\d{3}\.?\d{3}-?\d{2}\b"
regex_cnpj = r"\b\d{2}\.?\d{3}\.?\d{3}/?\d{4}-?\d{2}\b"
remove_char = lambda x: re.sub(r"[^\d]", "", x)

linhas_dados_extraidos = []

if os.path.exists(arquivo_path):
    # Inicializa EasyOCR uma única vez
    reader_ocr = easyocr.Reader(['pt'], gpu=False)
    
    doc = fitz.open(arquivo_path)
    
    for i, pagina in enumerate(doc):
        page_label = f"Page{i+1:04}"
        texto_pagina = pagina.get_text("text")
        
        # Se a página for imagem (pouco texto nativo), usa OCR
        if len(texto_pagina.strip()) < 15:
            log.info(f" -> {page_label}: Detectada como imagem. Processando OCR...")
            # Matrix(2,2) aumenta a resolução para não errar números
            pix = pagina.get_pixmap(matrix=fitz.Matrix(2, 2))
            img_bytes = pix.tobytes("png")
            resultados = reader_ocr.readtext(img_bytes, detail=0)
            texto_pagina = " ".join(resultados)
        
        # Processamento das linhas capturadas
        linhas = texto_pagina.split("\n")
        for num_linha, linha in enumerate(linhas):
            for tipo, regex in [("CPF", regex_cpf), ("CNPJ", regex_cnpj)]:
                for doc_encontrado in re.findall(regex, linha):
                    doc_limpo = remove_char(doc_encontrado)
                    # Filtra apenas se o tamanho for válido
                    if (tipo == "CPF" and len(doc_limpo) == 11) or (tipo == "CNPJ" and len(doc_limpo) == 14):
                        linhas_dados_extraidos.append({
                            "Page": page_label,
                            "Linha": num_linha,
                            "ClienteCpfCnpj": formatar_documento(doc_limpo, tipo),
                            "ClienteCpfCnpj_formatado": doc_limpo,
                            "Tipo": tipo,
                            "Texto": linha.strip()[:200] # Limita tamanho do texto para o SQL
                        })
    doc.close()
    log.info(f" Etapa 02/04: Leitura concluída. {len(linhas_dados_extraidos)} documentos encontrados.")
else:
    log.error(f"Arquivo não encontrado: {arquivo_path}")

# --- PROCESSAMENTO DATA FRAME E SQL ---
if linhas_dados_extraidos:
    pdf_paginas = pd.DataFrame(linhas_dados_extraidos)
    query_paginas = gerar_variavel_string_split(pdf_paginas)
    
    query_select_Oficio_Juridico = """
    SELECT DISTINCT 
           c.[ClienteCpfCnpj] AS CPF_CNPJ
        ,  c.[Page] AS Id
        ,  c.[Tipo]
        ,  ce.[CertificadoName]
        ,  CASE 
             WHEN sta.[StatusApoliceDescricao] <> 'CANCELADO' and ce.[CertificadoVigenciaFim] < CONVERT(char(8),getdate(),112)  THEN 'EXPIRADO'
             WHEN sta.[StatusApoliceDescricao] <> 'CANCELADO' and ce.[CertificadoVigenciaFim] >= CONVERT(char(8),getdate(),112) THEN 'ATIVO'
             ELSE sta.[StatusApoliceDescricao] END AS StatusCertificado
        ,  ce.OrigemDadoId
        ,  ce.[CertificadoVigenciaInicio]
        ,  ce.[CertificadoVigenciaFim]
        ,  s.SinistroName
    FROM (  
        SELECT c.[ClienteId], c.[OrigemDadoId], c.[ClienteName], v.[ClienteCpfCnpj], v.[Page], v.[Tipo]
        FROM [dbDMCardif].[dbo].[Cliente] c
        JOIN @Valores v ON c.[ClienteCpfCnpj] = v.[ClienteCpfCnpj_formatado]
      ) c
    LEFT JOIN [dbDMCardif].[dbo].[Certificado] ce ON c.[ClienteId] = ce.[ClienteId] AND c.[OrigemDadoId] = ce.[OrigemDadoId]
    AND ce.[CertificadoEndossoName] = 0 AND CONVERT(char(8),getdate()-1096,112) between ce.[CertificadoVigenciaInicio] and ce.[CertificadoVigenciaFim]
    LEFT JOIN [dbDMCardif].[dbo].[SinistroEvento] sv ON sv.[CertificadoID] = ce.[CertificadoId]
    LEFT JOIN [dbDMCardif].[dbo].[Sinistro] s ON s.[SinistroID] = sv.[SinistroID]
    LEFT JOIN [dbDMCardif].[dbo].[StatusApolice] sta on sta.[StatusApoliceId] = ce.[StatusApoliceId]
    WHERE ce.CertificadoName IS NOT NULL
    ORDER BY c.[Page]
    """
    
    query_final = query_paginas + "\n" + query_select_Oficio_Juridico
    
    # Execução no Banco
    conexao = info_conexao(server='SAOS005BI01P', driver='SQL Server')
    if conexao:
        cursor = conexao.cursor()
        cursor.execute(query_final)
        columns = [column[0] for column in cursor.description]
        df_final = pd.DataFrame.from_records(cursor.fetchall(), columns=columns)
        df_final['SinistroName'] = df_final['SinistroName'].replace(np.nan, "NULL")
        conexao.close()
        
        # Exportação
        log.info(" Etapa 04/04: Exportando para Excel...")
        caminho_excel = diretorio + f"ExtFinal_Oficio_{dt.now().strftime('%m_%Y')}.xlsx"
        df_final.to_excel(caminho_excel, index=False)
        log.info(f"Sucesso! Arquivo gerado: {caminho_excel}")
        
        # Limpeza do arquivo original (opcional)
        # os.remove(arquivo_path)
    else:
        log.error("Não foi possível conectar ao SQL Server.")
else:
